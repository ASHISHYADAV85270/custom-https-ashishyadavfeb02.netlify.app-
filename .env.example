# Copy to .env for local dev. On Netlify, add these in:
# Site configuration → Environment variables (then redeploy).

# Client-side (required VITE_ prefix for Vite)
VITE_CV_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing
VITE_INTRO_VIDEO_URL=https://www.youtube.com/embed/YOUR_VIDEO_ID?start=9
VITE_ENABLE_CHATBOT=false
VITE_CHAT_API_URL=

# Server-only (local `npm run dev:api` — not used on static Netlify hosting)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://your-site.netlify.app
OPENROUTER_APP_NAME=Ashish Portfolio
PORT=8787
